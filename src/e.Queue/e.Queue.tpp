// КОНСТРУКТОР И ДЕСТРУКТОР
// ============================================================================

// Конструктор
template <typename T>
Queue<T>::Queue() : front_(nullptr), end_(nullptr), size_(0) {}

// Деструктор
template <typename T>
Queue<T>::~Queue() {
  while (front_ != nullptr) {
    pop();  // используем существующий метод
  }
}