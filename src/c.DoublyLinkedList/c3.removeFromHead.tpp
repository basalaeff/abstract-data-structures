// ============================================================================
// C3 Удаление элемента из головы: CDELHEAD
// ============================================================================
// 1) Если список пуст, функция завершается.
// 2) Сохраняется указатель на удаляемый узел (head_).
// 3) head_ перемещается на следующий элемент (head_->next_).
// 4) Если после удаления список не стал пустым — у новой головы prev_
// устанавливается в nullptr.
// 5) Если список стал пустым — tail_ также устанавливается в nullptr.
// 6) Освобождается память удалённого узла.
// 7) Уменьшается размер списка (size_--).
// Сложность: O(1)

template <typename T>
void DoublyLinkedList<T>::removeFromHead() {
  if (head_ == nullptr) {
    return;
  }
  DoublyNode<T>* temp = head_;
  head_ = head_->next_;
  if (head_ != nullptr) {
    head_->prev_ = nullptr;
  } else {
    tail_ = nullptr;  // список стал пустым
  }
  delete temp;
  size_--;
}