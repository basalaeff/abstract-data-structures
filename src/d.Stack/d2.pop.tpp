
// ==================================================================
// D2 Удаление элемента: DPOP
// ============================================================================
// 1) Если стек пуст, выбрасывается исключение.
// 2) Сохраняется указатель на текущую вершину стека (temp = top_).
// 3) top_ перемещается на следующий элемент (top_->next_).
// 4) Освобождается память удалённого узла.
// 5) Уменьшается размер стека.
// Стек работает по принципу LIFO (Last In, First Out).
// Сложность: O(1)

template <typename T>
void Stack<T>::pop() {
  if (top_ == nullptr) {
    throw std::out_of_range("Stack is empty.");
  }
  Node<T>* temp = top_;
  top_ = top_->next_;
  delete temp;
  size_--;
}